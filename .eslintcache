:"2423"},{"range":"2511","text":"2450"},"Replace `'[WindowState]·Failed·to·save·state:',·err)` with `\"[WindowState]·Failed·to·save·state:\",·err);`",{"range":"2512","text":"2513"},{"range":"2514","text":"2423"},{"range":"2515","text":"2423"},{"range":"2516","text":"2423"},{"range":"2517","text":"2423"},{"range":"2518","text":"2423"},{"range":"2519","text":"2423"},{"range":"2520","text":"2423"},{"range":"2521","text":"2423"},{"range":"2522","text":"2423"},{"range":"2523","text":"2423"},{"range":"2524","text":"2423"},{"range":"2525","text":"2423"},{"range":"2526","text":"2423"},{"range":"2527","text":"2423"},{"range":"2528","text":"2423"},{"range":"2529","text":"2423"},{"range":"2530","text":"2423"},"Replace `'resize',·scheduleSave)` with `\"resize\",·scheduleSave);`",{"range":"2531","text":"2532"},"Replace `'move',·scheduleSave)` with `\"move\",·scheduleSave);`",{"range":"2533","text":"2534"},"Replace `'maximize'` with `\"maximize\"`",{"range":"2535","text":"2536"},{"range":"2537","text":"2423"},{"range":"2538","text":"2423"},{"range":"2539","text":"2423"},{"range":"2540","text":"2423"},"Replace `'unmaximize'` with `\"unmaximize\"`",{"range":"2541","text":"2542"},{"range":"2543","text":"2423"},{"range":"2544","text":"2423"},{"range":"2545","text":"2423"},{"range":"2546","text":"2423"},"Replace `'close'` with `\"close\"`",{"range":"2547","text":"2548"},{"range":"2549","text":"2423"},{"range":"2550","text":"2423"},{"range":"2551","text":"2423"},{"range":"2552","text":"2423"},{"range":"2553","text":"2423"},{"range":"2554","text":"2423"},{"range":"2555","text":"2423"},{"range":"2556","text":"2423"},{"range":"2557","text":"2423"},{"range":"2558","text":"2423"},{"range":"2559","text":"2423"},{"range":"2560","text":"2423"},{"range":"2561","text":"2411"},{"range":"2562","text":"2423"},"@typescript-eslint/explicit-function-return-type","Missing return type on function.","ArrowFunctionExpression","missingReturnType","Replace `'react'` with `\"react\";`",{"range":"2563","text":"2564"},{"range":"2565","text":"2423"},{"range":"2566","text":"2423"},{"range":"2567","text":"2423"},{"range":"2568","text":"2423"},{"range":"2569","text":"2423"},{"range":"2570","text":"2423"},"Replace `'[ErrorBoundary]·Caught·error:',·error,·info)` with `\"[ErrorBoundary]·Caught·error:\",·error,·info);`",{"range":"2571","text":"2572"},"Replace `'flex'` with `\"flex\"`",{"range":"2573","text":"2574"},"Replace `'column'` with `\"column\"`",{"range":"2575","text":"2576"},"Replace `'center'` with `\"center\"`",{"range":"2577","text":"2578"},{"range":"2579","text":"2578"},"Replace `'100%'` with `\"100%\"`",{"range":"2580","text":"2581"},"Replace `'var(--bg-base)'` with `\"var(--bg-base)\"`",{"range":"2582","text":"2583"},"Replace `'var(--text-secondary)'` with `\"var(--text-secondary)\"`",{"range":"2584","text":"2585"},"Replace `'var(--font-ui)'` with `\"var(--font-ui)\"`",{"range":"2586","text":"2587"},"Replace `'16px'` with `\"16px\"`",{"range":"2588","text":"2589"},"Replace `'32px'` with `\"32px\",`",{"range":"2590","text":"2591"},"Replace `'14px',·color:·'var(--text-primary)'·}}>Something·went·wrong` with `\"14px\",·color:·\"var(--text-primary)\"·}}>⏎············Something·went·wrong⏎··········`",{"range":"2592","text":"2593"},"Replace `'12px'` with `\"12px\"`",{"range":"2594","text":"2595"},"Replace `'var(--text-lo)'` with `\"var(--text-lo)\"`",{"range":"2596","text":"2597"},"Replace `'var(--font-mono)'` with `\"var(--font-mono)\"`",{"range":"2598","text":"2599"},"Replace `'480px'` with `\"480px\"`",{"range":"2600","text":"2601"},"Replace `'break-word'` with `\"break-word\"`",{"range":"2602","text":"2603"},"Replace `'center'` with `\"center\",`",{"range":"2604","text":"2605"},"Replace `'6px·16px'` with `\"6px·16px\"`",{"range":"2606","text":"2607"},"Replace `'var(--bg-elevated)'` with `\"var(--bg-elevated)\"`",{"range":"2608","text":"2609"},"Replace `'1px·solid·var(--border)'` with `\"1px·solid·var(--border)\"`",{"range":"2610","text":"2611"},"Replace `'var(--radius-md)'` with `\"var(--radius-md)\"`",{"range":"2612","text":"2613"},"Replace `'var(--text-primary)'` with `\"var(--text-primary)\"`",{"range":"2614","text":"2615"},{"range":"2616","text":"2587"},"Replace `'13px'` with `\"13px\"`",{"range":"2617","text":"2618"},"Replace `'pointer'` with `\"pointer\",`",{"range":"2619","text":"2620"},{"range":"2621","text":"2423"},{"range":"2622","text":"2423"},"react-hooks/set-state-in-effect","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/victor/test/grove/.worktrees/T-006/src/renderer/src/components/Files/FileSearch.tsx:136:5\n  134 |   // Reset selected index when results change\n  135 |   useEffect(() => {\n> 136 |     setSelectedIndex(0);\n      |     ^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  137 |   }, [results.length]);\n  138 |\n  139 |   // Focus input when searchFocusCounter changes","react-hooks/refs","Error: Cannot access refs during render\n\nReact refs are values that are not needed for rendering. Refs should only be accessed outside of render, such as in event handlers or effects. Accessing a ref value (the `current` property) during render can cause your component not to update as expected (https://react.dev/reference/react/useRef).\n\n/Users/victor/test/grove/.worktrees/T-006/src/renderer/src/components/Files/FileTree.tsx:154:3\n  152 |\n  153 |   // Keep ref in sync for keyboard handler\n> 154 |   focusedIndexRef.current = focusedIndex;\n      |   ^^^^^^^^^^^^^^^^^^^^^^^ Cannot update ref during render\n  155 |\n  156 |   const scrollToIndex = useCallback((index: number) => {\n  157 |     const container = scrollRef.current;","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/victor/test/grove/.worktrees/T-006/src/renderer/src/components/Files/FileViewer.tsx:59:7\n  57 |   useEffect(() => {\n  58 |     if (!fileContent || !highlighterReady) {\n> 59 |       setTokenLines(null);\n     |       ^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  60 |       return;\n  61 |     }\n  62 |","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/victor/test/grove/.worktrees/T-006/src/renderer/src/components/Files/FileViewer.tsx:106:7\n  104 |       prevContentRef.current !== fileContent.content\n  105 |     ) {\n> 106 |       setFlashKey((k) => k + 1);\n      |       ^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  107 |     }\n  108 |     prevContentRef.current = fileContent.content;\n  109 |   }, [fileContent]);",{"range":"2623","text":"2574"},{"range":"2624","text":"2578"},"Replace `'8px'` with `\"8px\"`",{"range":"2625","text":"2626"},"Replace `'10px·16px'` with `\"10px·16px\"`",{"range":"2627","text":"2628"},"Replace `'40px'` with `\"40px\"`",{"range":"2629","text":"2630"},"Replace `'1px·solid·var(--border-dim)'` with `\"1px·solid·var(--border-dim)\",`",{"range":"2631","text":"2632"},{"range":"2633","text":"2585"},{"range":"2634","text":"2587"},"Replace `'15px'` with `\"15px\"`",{"range":"2635","text":"2636"},{"range":"2637","text":"2615"},"Replace `'-0.01em'` with `\"-0.01em\",`",{"range":"2638","text":"2639"},{"range":"2640","text":"2423"},{"range":"2641","text":"2564"},{"range":"2642","text":"2423"},{"range":"2643","text":"2423"},{"range":"2644","text":"2423"},{"range":"2645","text":"2423"},{"range":"2646","text":"2423"},"Replace `·x,·y,·workspaceName,·onRemove,·onClose·` with `⏎··x,⏎··y,⏎··workspaceName,⏎··onRemove,⏎··onClose,⏎`",{"range":"2647","text":"2648"},{"range":"2649","text":"2423"},{"range":"2650","text":"2423"},"Replace `'Escape'` with `\"Escape\"`",{"range":"2651","text":"2652"},{"range":"2653","text":"2423"},"Replace `'mousedown',·handleClickOutside)` with `\"mousedown\",·handleClickOutside);`",{"range":"2654","text":"2655"},"Replace `'keydown',·handleKeyDown)` with `\"keydown\",·handleKeyDown);`",{"range":"2656","text":"2657"},{"range":"2658","text":"2655"},{"range":"2659","text":"2657"},{"range":"2660","text":"2423"},{"range":"2661","text":"2423"},{"range":"2662","text":"2423"},{"range":"2663","text":"2423"},{"range":"2664","text":"