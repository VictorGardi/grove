\"<h1>$1</h1>\")\n    // Bold + italic\n    .replace(/\\*\\*\\*(.+?)\\*\\*\\*/g, \"<strong><em>$1</em></strong>\")\n    .replace(/\\*\\*(.+?)\\*\\*/g, \"<strong>$1</strong>\")\n    .replace(/\\*(.+?)\\*/g, \"<em>$1</em>\")\n    // Inline code\n    .replace(/`([^`]+)`/g, \"<code>$1</code>\")\n    // Checkboxes\n    .replace(\n      /^- \\[x\\] (.+)$/gm,\n      '<div class=\"checkbox checked\"><input type=\"checkbox\" checked disabled /> <s>$1</s></div>',\n    )\n    .replace(\n      /^- \\[ \\] (.+)$/gm,\n      '<div class=\"checkbox\"><input type=\"checkbox\" disabled /> $1</div>',\n    )\n    // Unordered lists\n    .replace(/^- (.+)$/gm, \"<li>$1</li>\")\n    // Horizontal rules\n    .replace(/^---$/gm, \"<hr />\")\n    // Paragraphs (double newlines)\n    .replace(/\\n\\n/g, \"</p><p>\")\n    // Single newlines within paragraphs\n    .replace(/\\n/g, \"<br />\");",{"desc":"3303","fix":"3304"},{"desc":"3305","fix":"3306"},{"kind":"3307","justification":"3308"},[19,42],"\"./TitleBar.module.css\";",[104,104],[136,136],[166,191],"\n  platform,\n  workspaceName,\n",[259,267],"\"darwin\";",[478,478],[7,28],"\"./styles/global.css\";",[57,64],[92,110],"\"react-dom/client\";",[127,134],"\"./App\";",[171,177],"\"root\"",[231,231],[233,233],[23,32],"\"zustand\";",[68,91],"\"../../../shared/types\";",[149,149],[186,186],[205,205],[228,228],[281,281],[317,317],[368,368],[422,422],[477,477],[709,709],[860,860],[869,869],[955,955],[970,970],[1056,1056],[1158,1158],[1167,1167],[1254,1254],[1296,1296],[1391,1391],[1448,1448],[1461,1461],[1535,1535],[1652,1652],[1709,1709],[1722,1722],[1762,1762],[1879,1879],[1936,1936],[1949,1949],[1994,1994],[2167,2167],[2175,2175],[2183,2183],[2187,2187],[2191,2191],[13,101],"\n  WorkspaceEntry,\n  WorkspaceInfo,\n  AppConfig,\n  IpcResult,\n  WindowState,\n} from \"@shared/types\";",[29,44],[66,102],[136,178],[209,230],[266,293],[331,360],[405,443],[559,572],[627,635],[643,643],[649,649],[671,686],[710,723],[755,796],[928,928],[934,934],[962,9