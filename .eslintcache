ended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/victor/test/grove/.worktrees/T-006/src/renderer/src/components/TaskDetail/TaskDetailPanel.tsx:80:7\n  78 |   useEffect(() => {\n  79 |     if (selectedTaskBody !== null) {\n> 80 |       setParsed(parseTaskBody(selectedTaskBody));\n     |       ^^^^^^^^^ Avoid calling setState() directly within an effect\n  81 |     } else {\n  82 |       setParsed({\n  83 |         description: \"\",","react-hooks/exhaustive-deps","React Hook useEffect has missing dependencies: 'cwd' and 'id'. Either include them or remove the dependency array.","ArrayExpression",["2823"],["2824"],"Replace `'./TitleBar.module.css'` with `\"./TitleBar.module.css\";`",{"range":"2825","text":"2826"},{"range":"2827","text":"2423"},{"range":"2828","text":"2423"},"Replace `·platform,·workspaceName·` with `⏎··platform,⏎··workspaceName,⏎`",{"range":"2829","text":"2830"},"Replace `'darwin'` with `\"darwin\";`",{"range":"2831","text":"2832"},{"range":"2833","text":"2423"},"Replace `'./styles/global.css'` with `\"./styles/global.css\";`",{"range":"2834","text":"2835"},{"range":"2836","text":"2564"},"Replace `'react-dom/client'` with `\"react-dom/client\";`",{"range":"2837","text":"2838"},"Replace `'./App'` with `\"./App\";`",{"range":"2839","text":"2840"},"Replace `'root'` with `\"root\"`",{"range":"2841","text":"2842"},{"range":"2843","text":"2411"},{"range":"2844","text":"2423"},"Replace `'zustand'` with `\"zustand\";`",{"range":"2845","text":"2846"},"Replace `'../../../shared/types'` with `\"../../../shared/types\";`",{"range":"2847","text":"2848"},{"range":"2849","text":"2423"},{"range":"2850","text":"2423"},{"range":"2851","text":"2423"},{"range":"2852","text":"2423"},{"range":"2853","text":"2423"},{"range":"2854","text":"2423"},{"range":"2855","text":"2423"},{"range":"2856","text":"2423"},{"range":"2857","text":"2423"},{"range":"2858","text":"2423"},{"range":"2859","text":"2411"},{"range":"2860","text":"2423"},{"range":"2861","text"