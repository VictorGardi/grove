e":"2790","text":"2791"},"Replace `'none'` with `\"none\",`",{"range":"2792","text":"2793"},{"range":"2794","text":"2613"},{"range":"2795","text":"2617"},"Replace `'6px'` with `\"6px\",`",{"range":"2796","text":"2797"},{"range":"2798","text":"2624"},{"range":"2799","text":"2626"},{"range":"2800","text":"2657"},{"range":"2801","text":"2654"},{"range":"2802","text":"2713"},"Replace `'ellipsis'` with `\"ellipsis\"`",{"range":"2803","text":"2804"},"Replace `'nowrap'` with `\"nowrap\",`",{"range":"2805","text":"2806"},{"range":"2807","text":"2638"},{"range":"2808","text":"2719"},"Replace `'var(--text-lo)'` with `\"var(--text-lo)\",`",{"range":"2809","text":"2810"},{"range":"2811","text":"2613"},{"range":"2812","text":"2617"},"Replace `'4px'` with `\"4px\"`",{"range":"2813","text":"2814"},"Replace `'2px'` with `\"2px\"`",{"range":"2815","text":"2816"},"Replace `'26px'` with `\"26px\",`",{"range":"2817","text":"2818"},{"range":"2819","text":"2636"},"Replace `·cx=\"4\"·cy=\"4\"·r=\"2\"·stroke=\"currentColor\"·strokeWidth=\"1.5\"` with `⏎················cx=\"4\"⏎················cy=\"4\"⏎················r=\"2\"⏎················stroke=\"currentColor\"⏎················strokeWidth=\"1.5\"⏎·············`",{"range":"2820","text":"2821"},"Replace `·cx=\"12\"·cy=\"12\"·r=\"2\"·stroke=\"currentColor\"·strokeWidth=\"1.5\"` with `⏎················cx=\"12\"⏎················cy=\"12\"⏎················r=\"2\"⏎················stroke=\"currentColor\"⏎················strokeWidth=\"1.5\"⏎·············`",{"range":"2822","text":"2823"},"Replace `·cx=\"12\"·cy=\"4\"·r=\"2\"·stroke=\"currentColor\"·strokeWidth=\"1.5\"` with `⏎················cx=\"12\"⏎················cy=\"4\"⏎················r=\"2\"⏎················stroke=\"currentColor\"⏎················strokeWidth=\"1.5\"⏎·············`",{"range":"2824","text":"2825"},{"range":"2826","text":"2638"},{"range":"2827","text":"2719"},{"range":"2828","text":"2636"},{"range":"2829","text":"2713"},{"range":"2830","text":"2804"},{"range":"2831","text":"2806"},{"range":"2832","text":"2460"},{"range":"2833","text":"2754"},"Replace `'./WorkspaceItem'` with `\"./WorkspaceItem\";`",{"range":"2834","text":"2835"},{"range":"2836","text":"2460"},{"range":"2837","text":"2460"},{"range":"2838","text":"2460"},{"range":"2839","text":"2460"},{"range":"2840","text":"2613"},{"range":"2841","text":"2617"},"Replace `'6px'` with `\"6px\"`",{"range":"2842","text":"2843"},{"range":"2844","text":"2620"},{"range":"2845","text":"2646"},{"range":"2846","text":"2731"},{"range":"2847","text":"2733"},{"range":"2848","text":"2636"},{"range":"2849","text":"2626"},{"range":"2850","text":"2634"},{"range":"2851","text":"2741"},{"range":"2852","text":"2739"},"Replace `'color·var(--transition-fast)'` with `\"color·var(--transition-fast)\",`",{"range":"2853","text":"2854"},"Replace `;(e.currentTarget·as·HTMLButtonElement).style.color·=·'var(--text-secondary)'` with `(e.currentTarget·as·HTMLButtonElement).style.color·=⏎············\"var(--text-secondary)\";`",{"range":"2855","text":"2856"},"Replace `;(e.currentTarget·as·HTMLButtonElement).style.color·=·'var(--text-lo)'` with `(e.currentTarget·as·HTMLButtonElement).style.color·=·\"var(--text-lo)\";`",{"range":"2857","text":"2858"},"Replace `'currentColor'` with `\"currentColor\"`",{"range":"2859","text":"2860"},{"range":"2861","text":"2460"},"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/victor/test/grove/.worktrees/T-012/src/renderer/src/components/TaskDetail/ChangesTab.tsx:146:5\n  144 |   useEffect(() => {\n  145 |     let cancelled = false;\n> 146 |     setLoading(true);\n      |     ^^^^^^^^^^ Avoid calling setState() directly within an effect\n  147 |     setError(null);\n  148 |     setShowAll(false);\n  149 |","prefer-const","'html' is never reassigned. Use 'const' instead.","Identifier","useConst",{"range":"2862","text":"2863"},"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/victor/test/grove/.worktrees/T-012/src/renderer/src/components/TaskDetail/TaskDetailPanel.tsx:107:5\n  105 |   // Reset to edit tab when task changes\n  106 |   useEffect(() => {\n> 107 |     setActiveTab(\"edit\");\n      |     ^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  108 |   }, [task?.id]);\n  109 |\n  110 |   // ── Load raw file content ─────────────────────────────────────","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/victor/test/grove/.worktrees/T-012/src/renderer/src/components/TaskDetail/TaskDetailPanel.tsx:114:7\n  112 |   useEffect(() => {\n  113 |     if (!task || !workspacePath) {\n> 114 |       setRawContent(\"\");\n      |       ^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  115 |       setSavedContent(\"\");\n  116 |       setLoading(false);\n  117 |       return;","react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'task'. Either include it or remove the dependency array.","ArrayExpression",["2864"],"React Hook useEffect has missing dependencies: 'cwd' and 'id'. Either include them or remove the dependency array.",["2865"],["2866"],"Replace `'./TitleBar.module.css'` with `\"./TitleBar.module.css\";`",{"range":"2867","text":"2868"},{"range":"2869","text":"2460"},{"range":"2870","text":"2460"},"Replace `·platform,·workspaceName·` with `⏎··platform,⏎··workspaceName,⏎`",{"range":"2871","text":"2872"},"Replace `'darwin'` with `\"darwin\";`",{"range":"2873","text":"2874"},{"range":"2875","text":"2460"},"Replace `'./styles/global.css'` with `\"./styles/global.css\";`",{"range":"2876","text":"2877"},{"range":"2878","text":"2603"},"Replace `'react-dom/client'` with `\"react-dom/client\";`",{"range":"2879","text":"2880"},"Replace `'./App'` with `\"./App\";`",{"range":"2881","text":"2882"},"Replace `'root'` with `\"root\"`",{"range":"2883","text":"2884"},{"range":"2885","text":"2448"},{"range":"2886","text":"2460"},"Replace `'zustand'` with `\"zustand\";`",{"range":"2887","text":"2888"},"Replace `'../../../shared/types'` with `\"../../../shared/types\";`",{"range":"2889","text":"2890"},{"range":"2891","text":"2460"},{"range":"2892","text":"2460"},{"range":"2893","text":"2460"},{"range":"2894","text":"2460"},{"range":"2895","text":"2460"},{"range":"2896","text":"2460"},{"range":"2897","text":"2460"},{"range":"2898","text":"2460"},{"range":"2899","text":"2460"},{"range":"2900","text":"2460"},{"range":"2901","text":"2448"},{"range":"2902","text":"2460"},{"range":"2903","text":"2460"},{"range":"2904","text":"2460"},{"range":"2905","text":"2460"},{"range":"2906","text":"2448"},{"range":"2907","text":"2460"},{"range":"2908","text":"2460"},{"range":"2909","text":"2460"},{"range":"2910","text":"2460"},{"range":"2911","text":"2460"},{"range":"2912","text":"2460"},{"range":"2913","text":"2460"},{"range":"2914","text":"2460"},{"range":"2915","text":"2460"},{"range":"2916","text":"2460"},{"range":"2917","text":"2460"},{"range":"2918","text":"2460"},{"range":"2919","text":"2460"},{"range":"2920","text":"2460"},{"range":"2921","text":"2460"},{"range":"2922","text":"2448"},{"range":"2923","text":"2448"},{"range":"2924","text":"2460"},{"range":"2925","text":"2448"},{"range":"2926","text":"2460"},"Replace `·WorkspaceEntry,·WorkspaceInfo,·AppConfig,·IpcResult,·WindowState·}·from·'@shared/types'` with `⏎··WorkspaceEntry,⏎··WorkspaceInfo,⏎··AppConfig,⏎··IpcResult,⏎··WindowState,⏎}·from·\"@shared/types\";`",{"range":"2927","text":"2928"},{"range":"2929","text":"2430"},{"range":"2930","text":"2432"},{"range":"2931","text":"2434"},{"range":"2932","text":"2436"},{"range":"2933","text":"2438"},{"range":"2934","text":"2440"},{"range":"2935","text":"2442"},{"range":"2936","text":"2444"},{"range":"2937","text":"2446"},{"range":"2938","text":"2448"},{"range":"2939","text":"2448"},{"range":"2940","text":"2451"},{"range":"2941","text":"2453"},{"range":"2942","text":"2455"},{"range":"2943","text":"2448"},{"range":"2944","text":"2448"},{"range":"2945","text":"2448"},{"range":"2946","text":"2460"},{"range":"2947","text":"2462"},{"range":"2948","text":"2464"},{"range":"2949","text":"2466"},{"range":"2950","text":"2468"},{"range":"2951","text":"2448"},{"range":"2952","text":"2460"},{"range":"2953","text":"2460"},{"range":"2954","text":"2460"},{"range":"2955","text":"2460"},{"range":"2956","text":"2475"},{"range":"2957","text":"2460"},{"range":"2958","text":"2460"},{"range":"2959","text":"2460"},{"range":"2960","text":"2460"},{"range":"2961","text":"2460"},{"range":"2962","text":"2460"},{"range":"2963","text":"2460"},{"range":"2964","text":"2460"},{"range":"2965","text":"2460"},{"range":"2966","text":"2460"},{"range":"2967","text":"2487"},{"range":"2968","text":"2460"},{"range":"2969","text":"2490"},{"range":"2970","text":"2492"},{"range":"2971","text":"2448"},{"range":"2972","text":"2460"},{"range":"2973","text":"2496"},{"range":"2974","text":"2460"},{"range":"2975","text":"2499"},{"range":"2976","text":"2460"},{"range":"2977","text":"2460"},{"range":"2978","text":"2487"},{"range":"2979","text":"2460"},{"range":"2980","text":"2505"},{"range":"2981","text":"2460"},{"range":"2982","text":"2460"},"no-control-regex","Unexpected control character(s) in regular expression: \\x1b.","Literal","unexpected",{"range":"2983","text":"2462"},{"range":"2984","text":"2464"},{"range":"2985","text":"2466"},{"range":"2986","text":"2462"},{"range":"2987","text":"2462"},{"range":"2988","text":"2468"},{"range":"2989","text":"2448"},{"range":"2990","text":"2460"},{"range":"2991","text":"2460"},{"range":"2992","text":"2460"},{"range":"2993","text":"2460"},{"range":"2994","text":"2520"},{"range":"2995","text":"2460"},{"range":"2996","text":"2487"},{"range":"2997","text":"2460"},{"range":"2998","text":"2525"},{"range":"2999","text":"2525"},{"range":"3000","text":"2525"},{"range":"3001","text":"2525"},{"range":"3002","text":"2448"},{"range":"3003","text":"2460"},{"range":"3004","text":"2460"},{"range":"3005","text":"2460"},{"range":"3006","text":"2460"},{"range":"3007","text":"2460"},{"range":"3008","text":"2460"},{"range":"3009","text":"2460"},{"range":"3010","text":"2538"},{"range":"3011","text":"2460"},{"range":"3012","text":"2460"},{"range":"3013","text":"2460"},{"range":"3014","text":"2460"},{"range":"3015","text":"2460"},{"range":"3016","text":"2448"},{"range":"3017","text":"2460"},{"range":"3018","text":"2460"},{"range":"3019","text":"2460"},{"range":"3020","text":"2487"},{"range":"3021","text":"2550"},{"range":"3022","text":"2460"},{"range":"3023","text":"2460"},{"range":"3024","text":"2460"},{"range":"3025","text":"2460"},{"range":"3026","text":"2460"},{"range":"3027","text":"2460"},{"range":"3028","text":"2460"},{"range":"3029","text":"2460"},{"range":"3030","text":"2460"},{"range":"3031","text":"2460"},{"range":"3032","text":"2460"},{"range":"3033","text":"2460"},{"range":"3034","text":"2460"},{"range":"3035","text":"2460"},{"range":"3036","text":"2460"},{"range":"3037","text":"2460"},{"range":"3038","text":"2460"},{"range":"3039","text":"2569"},{"range":"3040","text":"2571"},{"range":"3041","text":"2573"},{"range":"3042","text":"2460"},{"range":"3043","text":"2460"},{"range":"3044","text":"2460"},{"range":"3045","text":"2460"},{"range":"3046","text":"2579"},{"range":"3047","text":"2460"},{"range":"3048","text":"2460"},{"range":"3049","text":"2460"},{"range":"3050","text":"2460"},{"range":"3051","text":"2585"},{"range":"3052","text":"2460"},{"range":"3053","text":"2460"},{"range":"3054","text":"2460"},{"range":"3055","text":"2460"},{"range":"3056","text":"2460"},{"range":"3057","text":"2460"},{"range":"3058","text":"2460"},{"range":"3059","text":"2460"},{"range":"3060","text":"2460"},{"range":"3061","text":"2460"},{"range":"3062","text":"2460"},{"range":"3063","text":"2460"},{"range":"3064","text":"2448"},{"range":"3065","text":"2460"},{"range":"3066","text":"2601"},{"range":"3067","text":"2603"},{"range":"3068","text":"2460"},{"range":"3069","text":"2460"},{"range":"3070","text":"2460"},{"range":"3071","text":"2460"},{"range":"3072","text":"2460"},{"range":"3073","text":"2460"},{"range":"3074","text":"2611"},{"range":"3075","text":"2613"},{"range":"3076","text":"2615"},{"range":"3077","text":"2617"},{"range":"3078","text":"2617"},{"range":"3079","text":"2620"},{"range":"3080","text":"2622"},{"range":"3081","text":"2624"},{"range":"3082","text":"2626"},{"range":"3083","text":"2628"},{"range":"3084","text":"2630"},{"range":"3085","text":"2632"},{"range":"3086","text":"2634"},{"range":"3087","text":"2636"},{"range":"3088","text":"2638"},{"range":"3089","text":"2640"},{"range":"3090","text":"2642"},{"range":"3091","text":"2644"},{"range":"3092","text":"2646"},{"range":"3093","text":"2648"},{"range":"3094","text":"2650"},{"range":"3095","text":"2652"},{"range":"3096","text":"2654"},{"range":"3097","text":"2626"},{"range":"3098","text":"2657"},{"range":"3099","text":"2659"},{"range":"3100","text":"2460"},{"range":"3101","text":"2460"},"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/victor/test/grove/src/renderer/src/components/Files/FileSearch.tsx:136:5\n  134 |   // Reset selected index when results change\n  135 |   useEffect(() => {\n> 136 |     setSelectedIndex(0);\n      |     ^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  137 |   }, [results.length]);\n  138 |\n  139 |   // Focus input when searchFocusCounter changes","Error: Cannot access refs during render\n\nReact refs are values that are not needed for rendering. Refs should only be accessed outside of render, such as in event handlers or effects. Accessing a ref value (the `current` property) during render can cause your component not to update as expected (https://react.dev/reference/react/useRef).\n\n/Users/victor/test/grove/src/renderer/src/components/Files/FileTree.tsx:154:3\n  152 |\n  153 |   // Keep ref in sync for keyboard handler\n> 154 |   focusedIndexRef.current = focusedIndex;\n      |   ^^^^^^^^^^^^^^^^^^^^^^^ Cannot update ref during render\n  155 |\n  156 |   const scrollToIndex = useCallback((index: number) => {\n  157 |     const container = scrollRef.current;","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/victor/test/grove/src/renderer/src/components/Files/FileViewer.tsx:60:5\n  58 |   // Reset to rendered view when opening a new file\n  59 |   useEffect(() => {\n> 60 |     setViewMode(\"rendered\");\n     |     ^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  61 |   }, [openFilePath]);\n  62 |\n  63 |   // Tokenize when file content or language changes","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/victor/test/grove/src/renderer/src/components/Files/FileViewer.tsx:66:7\n  64 |   useEffect(() => {\n  65 |     if (!fileContent || !highlighterReady) {\n> 66 |       setTokenLines(null);\n     |       ^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  67 |       return;\n  68 |     }\n  69 |","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/victor/test/grove/src/renderer/src/components/Files/FileViewer.tsx:111:7\n  109 |       prevContentRef.current !== fileContent.content\n  110 |     ) {\n> 111 |       setFlashKey((k) => k + 1);\n      |       ^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  112 |     }\n  113 |     prevContentRef.current = fileContent.content;\n  114 |   }, [fileContent]);","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/victor/test/grove/src/renderer/src/components/Files/MarkdownViewer.tsx:23:7\n  21 |       lang && SUPPORTED_LANGS.has(lang) && lang !== \"text\" ? lang : \"text\";\n  22 |     if (normalizedLang === \"text\") {\n> 23 |       setTokenLines(null);\n     |       ^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  24 |       return;\n  25 |     }\n  26 |     let cancelled = false;","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/victor/test/grove/src/renderer/src/components/Files/WorktreeSelector.tsx:40:5\n  38 |\n  39 |   useEffect(() => {\n> 40 |     loadBranches();\n     |     ^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  41 |   }, [loadBranches]);\n  42 |\n  43 |   // Refresh branch list when data changes (task moved to doing/done → new worktree)",{"range":"3102","text":"2613"},{"range":"3103","text":"2617"},{"range":"3104","text":"2665"},{"range":"3105","text":"2667"},{"range":"3106","text":"2669"},{"range":"3107","text":"2671"},{"range":"3108","text":"2624"},{"range":"3109","text":"2626"},{"range":"3110","text":"2675"},{"range":"3111","text":"2654"},{"range":"3112","text":"2678"},{"range":"3113","text":"2460"},{"range":"3114","text":"2603"},{"range":"3115","text":"2460"},{"range":"3116","text":"2460"},{"range":"3117","text":"2460"},{"range":"3118","text":"2460"},{"range":"3119","text":"2460"},{"range":"3120","text":"2687"},{"range":"3121","text":"2460"},{"range":"3122","text":"2460"},{"range":"3123","text":"2691"},{"range":"3124","text":"2460"},{"range":"3125","text":"2694"},{"range":"3126","text":"2696"},{"range":"3127","text":"2694"},{"range":"3128","text":"2696"},{"range":"3129","text":"2460"},{"range":"3130","text":"2460"},{"range":"3131","text":"2460"},{"range":"3132","text":"2460"},{"range":"3133","text":"2460"},{"range":"3134","text":"2460"},{"range":"3135","text":"2706"},{"range":"3136","text":"2648"},{"range":"3137","text":"2650"},{"range":"3138","text":"2652"},{"range":"3139","text":"2711"},{"range":"3140","text":"2713"},{"range":"3141","text":"2715"},{"range":"3142","text":"2717"},{"range":"3143","text":"2719"},{"range":"3144","text":"2636"},{"range":"3145","text":"2626"},{"range":"3146","text":"2650"},{"range":"3147","text":"2724"},{"range":"3148","text":"2726"},{"range":"3149","text":"2620"},{"range":"3150","text":"2729"},{"range":"3151","text":"2731"},{"range":"3152","text":"2733"},{"range":"3153","text":"2735"},{"range":"3154","text":"2626"},{"range":"3155","text":"2657"},{"range":"3156","text":"2739"},{"range":"3157","text":"2741"},{"range":"3158","text":"2743"},{"range":"3159","text":"2745"},{"range":"3160","text":"2747"},{"range":"3161","text":"2460"},{"range":"3162","text":"2603"},{"range":"3163","text":"2468"},{"range":"3164","text":"2752"},{"range":"3165","text":"2754"},{"range":"3166","text":"2756"},{"range":"3167","text":"2460"},{"range":"3168","text":"2460"},{"range":"3169","text":"2460"},{"range":"3170","text":"2761"},{"range":"3171","text":"2460"},{"range":"3172","text":"2764"},{"range":"3173","text":"2460"},{"range":"3174","text":"2460"},{"range":"3175","text":"2460"},{"range":"3176","text":"2460"},{"range":"3177","text":"2770"},{"range":"3178","text":"2460"},{"range":"3179","text":"2460"},{"range":"3180","text":"2460"},{"range":"3181","text":"2460"},{"range":"3182","text":"2460"},{"range":"3183","text":"2777"},{"range":"3184","text":"2779"},{"range":"3185","text":"2781"},{"range":"3186","text":"2741"},{"range":"3187","text":"2784"},{"range":"3188","text":"2786"},{"range":"3189","text":"2731"},{"range":"3190","text":"2789"},{"range":"3191","text":"2791"},{"range":"3192","text":"2793"},{"range":"3193","text":"2613"},{"range":"3194","text":"2617"},{"range":"3195","text":"2797"},{"range":"3196","text":"2624"},{"range":"3197","text":"2626"},{"range":"3198","text":"2657"},{"range":"3199","text":"2654"},{"range":"3200","text":"2713"},{"range":"3201","text":"2804"},{"range":"3202","text":"2806"},{"range":"3203","text":"2638"},{"range":"3204","text":"2719"},{"range":"3205","text":"2810"},{"range":"3206","text":"2613"},{"range":"3207","text":"2617"},{"range":"3208","text":"2814"},{"range":"3209","text":"2816"},{"range":"3210","text":"2818"},{"range":"3211","text":"2636"},{"range":"3212","text":"2821"},{"range":"3213","text":"2823"},{"range":"3214","text":"2825"},{"range":"3215","text":"2638"},{"range":"3216","text":"2719"},{"range":"3217","text":"2636"},{"range":"3218","text":"2713"},{"range":"3219","text":"2804"},{"range":"3220","text":"2806"},{"range":"3221","text":"2460"},{"range":"3222","text":"2754"},{"range":"3223","text":"2835"},{"range":"3224","text":"2460"},{"range":"3225","text":"2460"},{"range":"3226","text":"2460"},{"range":"3227","text":"2460"},{"range":"3228","text":"2613"},{"range":"3229","text":"2617"},{"range":"3230","text":"2843"},{"range":"3231","text":"2620"},{"range":"3232","text":"2646"},{"range":"3233","text":"2731"},{"range":"3234","text":"2733"},{"range":"3235","text":"2636"},{"range":"3236","text":"2626"},{"range":"3237","text":"2634"},{"range":"3238","text":"2741"},{"range":"3239","text":"2739"},{"range":"3240","text":"2854"},{"range":"3241","text":"2856"},{"range":"3242","text":"2858"},{"range":"3243","text":"2860"},{"range":"3244","text":"2460"},"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/victor/test/grove/src/renderer/src/components/TaskDetail/ChangesTab.tsx:146:5\n  144 |   useEffect(() => {\n  145 |     let cancelled = false;\n> 146 |     setLoading(true);\n      |     ^^^^^^^^^^ Avoid calling setState() directly within an effect\n  147 |     setError(null);\n  148 |     setShowAll(false);\n  149 |","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/victor/test/grove/src/renderer/src/components/TaskDetail/PlanChat.tsx:144:5\n  142 |   useEffect(() => {\n  143 |     if (!workspacePath) return;\n> 144 |     setModelsLoading(true);\n      |     ^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  145 |     window.api.plan\n  146 |       .listModels({ agent, workspacePath })\n  147 |       .then((result) => {",{"range":"3245","text":"2863"},"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/victor/test/grove/src/renderer/src/components/TaskDetail/TaskDetailPanel.tsx:116:7\n  114 |   useEffect(() => {\n  115 |     if (task?.status === \"backlog\") {\n> 116 |       setActiveTab(\"plan\");\n      |       ^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  117 |     } else {\n  118 |       setActiveTab(\"edit\");\n  119 |     }","React Hook useEffect has a missing dependency: 'task?.status'. Either include it or remove the dependency array.",["3246"],"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/victor/test/grove/src/renderer/src/components/TaskDetail/TaskDetailPanel.tsx:126:7\n  124 |   useEffect(() => {\n  125 |     if (!task || !workspacePath) {\n> 126 |       setRawContent(\"\");\n      |       ^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  127 |       setSavedContent(\"\");\n  128 |       setLoading(false);\n  129 |       return;",["3247"],["3248"],["3249"],["3250"],{"range":"3251","text":"2868"},{"range":"3252","text":"2460"},{"range":"3253","text":"2460"},{"range":"3254","text":"2872"},{"range":"3255","text":"2874"},{"range":"3256","text":"2460"},{"range":"3257","text":"2877"},{"range":"3258","text":"2603"},{"range":"3259","text":"2880"},{"range":"3260","text":"2882"},{"range":"3261","text":"2884"},{"range":"3262","text":"2448"},{"range":"3263","text":"2460"},{"range":"3264","text":"2888"},{"range":"3265","text":"2890"},{"range":"3266","text":"2460"},{"range":"3267","text":"2460"},{"range":"3268","text":"2460"},{"range":"3269","text":"2460"},{"range":"3270","text":"2460"},{"range":"3271","text":"2460"},{"range":"3272","text":"2460"},{"range":"3273","text":"2460"},{"range":"3274","text":"2460"},{"range":"3275","text":"2460"},{"range":"3276","text":"2448"},{"range":"3277","text":"2460"},{"range":"3278","text":"2460"},{"range":"3279","text":"2460"},{"range":"3280","text":"2460"},{"range":"3281","text":"2448"},{"range":"3282","text":"2460"},{"range":"3283","text":"2460"},{"range":"3284","text":"2460"},{"range":"3285","text":"2460"},{"range":"3286","text":"2460"},{"range":"3287","text":"2460"},{"range":"3288","text":"2460"},{"ra